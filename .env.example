# Email Credentials - Copy this to .env and fill in your details
# This file should NOT be committed to git - add .env to .gitignore

# Email Provider: gmail, outlook, yahoo, or other
EMAIL_PROVIDER=gmail

# Your email address
EMAIL_ADDRESS=xxxxxxx@gmail.com

# Your password or App Password (for Gmail/Yahoo, use App Password)
EMAIL_PASSWORD=xxxxxxxxxxxxx

# For custom IMAP/SMTP providers only:
# IMAP_HOST=imap.example.com
# IMAP_PORT=993
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
